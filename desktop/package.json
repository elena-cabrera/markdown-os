{
  "name": "markdown-os-desktop",
  "version": "0.9.3",
  "private": true,
  "description": "Electron shell for Markdown-OS",
  "main": "dist/main.js",
  "scripts": {
    "prepare:resources": "node ./scripts/run-python-script.mjs ../scripts/prepare_desktop_resources.py",
    "icon:mac": "../scripts/generate_macos_icon.sh",
    "build": "npm run prepare:resources && tsc -p tsconfig.json",
    "dev": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2"
  },
  "build": {
    "extends": "./electron-builder.yml"
  }
}
